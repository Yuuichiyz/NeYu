#!/data/data/com.termux/files/usr/bin/bash

# [PROTOCOLO DE AUTORIZAÇÃO] Concede permissões de uso ao Termux e ao ADB Shell automaticamente
adb shell "pm grant com.termux android.permission.PACKAGE_USAGE_STATS" 2>/dev/null
adb shell "appops set com.termux GET_USAGE_STATS allow" 2>/dev/null

# Paleta de Cores Platinum Neon
VERDE='\033[1;32m'
BRANCO='\033[1;37m'
AMARELO='\033[1;33m'
AZUL='\033[1;34m'
RED='\033[1;31m'
CYAN='\033[1;36m'
PURPLE='\033[1;35m'
RESET='\033[0m'

header() {
    clear
    echo -e "${CYAN}╭──────────────────────────────────────────────────────────────╮${RESET}"
    echo -e "${CYAN}│${BRANCO}          FORENSIC TITAN V71 - PLATINUM EDITION               ${CYAN}│${RESET}"
    echo -e "${CYAN}╰──────────────────────────────────────────────────────────────╯${RESET}"
}

progress_bar() {
    local label=$1
    echo -ne "${PURPLE}───[$label]${RESET} "
    for i in {1..25}; do 
        echo -ne "━"
        sleep 0.015
    done
    echo -e " ${VERDE}READY${RESET}"
}

format_size() {
    local size=$1
    if [ -z "$size" ] || [ "$size" -eq 0 ]; then 
        echo "0 B"
    elif [ "$size" -lt 1024 ]; then 
        echo "${size} B"
    elif [ "$size" -lt 1048576 ]; then 
        echo "$(($size / 1024)) KB"
    elif [ "$size" -lt 1073741824 ]; then 
        echo "$(($size / 1048576)) MB"
    else 
        echo "$(($size / 1073741824)) GB"
    fi
}

analyze_impact() {
    local path=$1
    local file=$(basename "$path")
    if [[ "$path" == *"/MReplays/"* ]]; then
        echo -e "${VERDE}[BAIXO]${RESET} | ${CYAN}Jogo${RESET} | Match Record (Arquivo gerado pelo motor do jogo)"
    elif [[ "$file" == *".lua"* ]]; then
        echo -e "${RED}[CRÍTICO]${RESET} | ${RED}Usuário${RESET} | Aimbot/Fly Script (Script externo detectado)"
    elif [[ "$file" == *".so"* ]]; then
        echo -e "${RED}[ALTO]${RESET} | ${RED}Injetor${RESET} | Bypass/Mod Menu (Possível modificação de memória)"
    elif [[ "$file" == *".apk"* ]]; then
        echo -e "${RED}[ALERTA]${RESET} | ${RED}Usuário${RESET} | App Suspeito (Instalador fora da Play Store)"
    elif [[ "$file" == *".html"* ]]; then
        echo -e "${AMARELO}[MÉDIO]${RESET} | ${RED}Usuário${RESET} | Painel/Log (Registro de atividade hacker)"
    elif [[ "$file" == *".sh"* ]]; then
        echo -e "${RED}[ALTO]${RESET} | ${RED}Usuário${RESET} | Shell Script (Executável de automação suspeito)"
    else 
        echo -e "${BRANCO}[COMUM]${RESET} | ${CYAN}Origem: Sistema${RESET} | Cache/Data (Uso genérico)"
    fi
}

get_file_info() {
    local path=$1
    local RAW_INFO=$(adb shell "stat -c '%s|%a|%x' '$path' 2>/dev/null")
    if [ -n "$RAW_INFO" ]; then
        local SIZE=$(echo "$RAW_INFO" | cut -d'|' -f1)
        local PERM=$(echo "$RAW_INFO" | cut -d'|' -f2)
        local ACCS=$(echo "$RAW_INFO" | cut -d'|' -f3 | cut -d'.' -f1)
        echo -e "  ${CYAN}├─${BRANCO} Tamanho:   ${RESET}$(format_size "$SIZE")"
        echo -e "  ${CYAN}├─${BRANCO} Permissões:${RESET} $PERM (Verificar rwx suspeito)"
        echo -e "  ${CYAN}└─${BRANCO} Acesso:    ${RESET}$ACCS"
    fi
}

usage_record_scan() {
    header
    echo -e "${PURPLE}═══ REGISTRO DE USO - PROTOCOLO DE FORÇA BRUTA (100 APPS) ═══${RESET}"
    local SUCCESS=0

    echo -ne "${CYAN}[MÉTODO 1] Forçando extração via Usagestats...${RESET} "
    local DATA1=$(adb shell "dumpsys usagestats" | grep -E "EVENT_|type=MOVE_TO_FOREGROUND" | tail -n 100)
    if [ -n "$DATA1" ]; then
        echo -e "${VERDE}SUCESSO${RESET}"
        SUCCESS=1
        echo -e "${AZUL}────────────────────────────────────────────────────────────────${RESET}"
        printf "${CYAN}%-20s │ %-s${RESET}\n" "HORÁRIO (H:M:S)" "PACOTE / APLICATIVO"
        echo -e "${AZUL}────────────────────────────────────────────────────────────────${RESET}"
        while read -r line; do
            local TIME=$(echo "$line" | grep -oE "(time|t)=\"[^\"]+\"|(time|t)=[^ ]+" | cut -d'=' -f2 | tr -d '"')
            local PKG=$(echo "$line" | grep -oE "(package|pkg)=\"[^\"]+\"|(package|pkg)=[^ ]+" | cut -d'=' -f2 | tr -d '"')
            [ -n "$PKG" ] && echo -e "${AMARELO}${TIME:----}${RESET} │ ${BRANCO}$PKG${RESET}"
        done <<< "$DATA1"
    else
        echo -e "${RED}FALHOU${RESET}"
    fi

    if [ "$SUCCESS" -eq 0 ]; then
        echo -ne "${CYAN}[MÉTODO 2] Buscando Pilha de Tarefas Recentes...${RESET} "
        local DATA2=$(adb shell "dumpsys activity recents" | grep "recentTasks" -A 100 | grep "realActivity" | head -n 100)
        if [ -n "$DATA2" ]; then
            echo -e "${VERDE}SUCESSO${RESET}"; SUCCESS=1
            echo -e "${AZUL}────────────────────────────────────────────────────────────────${RESET}"
            while read -r line; do
                local PKG=$(echo "$line" | cut -d'=' -f2 | cut -d'/' -f1 | xargs)
                echo -e "${AMARELO}Recent Task${RESET} │ ${BRANCO}$PKG${RESET}"
            done <<< "$DATA2"
        else
            echo -e "${RED}FALHOU${RESET}"
        fi
    fi

    if [ "$SUCCESS" -eq 0 ]; then
        echo -ne "${CYAN}[MÉTODO 3] Consultando LastUsed de Pacotes...${RESET} "
        local DATA3=$(adb shell "dumpsys package" | grep "lastUsed" -B 1 | grep "Package \[" | tail -n 100)
        if [ -n "$DATA3" ]; then
            echo -e "${VERDE}SUCESSO${RESET}"; SUCCESS=1
            echo -e "${AZUL}────────────────────────────────────────────────────────────────${RESET}"
            while read -r line; do
                local PKG=$(echo "$line" | cut -d'[' -f2 | cut -d']' -f1)
                echo -e "${AMARELO}Last Used${RESET} │ ${BRANCO}$PKG${RESET}"
            done <<< "$DATA3"
        else
            echo -e "${RED}FALHOU${RESET}"
        fi
    fi

    if [ "$SUCCESS" -eq 0 ]; then
        echo -ne "${CYAN}[MÉTODO 4] Analisando Estatísticas de Processos...${RESET} "
        local DATA4=$(adb shell "dumpsys procstats --hours 24" | grep "pkg:" | cut -d' ' -f4 | sort -u | tail -n 100)
        if [ -n "$DATA4" ]; then
            echo -e "${VERDE}SUCESSO${RESET}"; SUCCESS=1
            echo -e "${AZUL}────────────────────────────────────────────────────────────────${RESET}"
            while read -r pkg; do
                echo -e "${AMARELO}Process Log${RESET} │ ${BRANCO}$pkg${RESET}"
            done <<< "$DATA4"
        else
            echo -e "${RED}TODOS OS MÉTODOS FALHARAM${RESET}"
            echo -e "${AMARELO}DICA: Verifique se o dispositivo está autorizado via ADB.${RESET}"
        fi
    fi

    echo -e "${AZUL}────────────────────────────────────────────────────────────────${RESET}"
    read -p "Pressione Enter para voltar..."
}

system_integrity_scan() {
    header
    echo -e "${PURPLE}═══ AUDITORIA EXTENSIVA DE INTEGRIDADE E HARDWARE ═══${RESET}"
    progress_bar "MAPEANDO AMBIENTE DO SISTEMA"
    local INTEGRITY_FAIL=0

    # Identificação do Dispositivo
    local BRAND=$(adb shell "getprop ro.product.brand" 2>/dev/null | tr '[:lower:]' '[:upper:]')
    local MODEL=$(adb shell "getprop ro.product.model" 2>/dev/null)
    local FABRICANTE=$(adb shell "getprop ro.product.manufacturer" 2>/dev/null)
    local ANDROID_VER=$(adb shell "getprop ro.build.version.release" 2>/dev/null)
    local SDK_VER=$(adb shell "getprop ro.build.version.sdk" 2>/dev/null)
    local SERIAL=$(adb shell "getprop ro.serialno" 2>/dev/null)

    echo -e "\n${BRANCO}[ INFORMAÇÕES DO DISPOSITIVO ]${RESET}"
    echo -e "  ${CYAN}├─ Marca:      ${RESET}$BRAND"
    echo -e "  ${CYAN}├─ Fabricante: ${RESET}$FABRICANTE"
    echo -e "  ${CYAN}├─ Modelo:     ${RESET}$MODEL"
    echo -e "  ${CYAN}├─ Versão:     ${RESET}Android $ANDROID_VER (API $SDK_VER)"
    echo -e "  ${CYAN}└─ S/N:        ${RESET}$SERIAL"

    # Auditoria de Kernel (Stock vs Custom)
    echo -e "\n${BRANCO}[ ANÁLISE DE NÚCLEO (KERNEL) ]${RESET}"
    local KERNEL_NAME=$(adb shell "uname -r" 2>/dev/null)
    local KERNEL_VER=$(adb shell "uname -v" 2>/dev/null)
    
    # Detecção profunda baseada em strings comuns de custom kernels
    if [[ "$KERNEL_NAME" == *"perf"* || "$KERNEL_NAME" == *"generic"* || "$KERNEL_VER" == *"PREEMPT"* ]]; then
        echo -e "  ${VERDE}✔ STATUS: KERNEL ÍNTEGRO (STOCK DETECTADO)${RESET}"
        echo -e "  ${CYAN}└─ Assinatura:${RESET} $KERNEL_NAME"
    else
        echo -e "  ${RED}✖ STATUS: KERNEL MODIFICADO (CUSTOM DETECTADO)${RESET}"
        echo -e "  ${AMARELO}⚠ Alerta: Kernels modificados podem ocultar Root e Scripts.${RESET}"
        echo -e "  ${CYAN}└─ Assinatura:${RESET} $KERNEL_NAME | $KERNEL_VER"
        INTEGRITY_FAIL=1
    fi

    # Auditoria de Bootloader
    echo -e "\n${BRANCO}[ ESTADO DO BOOTLOADER ]${RESET}"
    local UNLOCKED=$(adb shell "getprop ro.boot.flash.locked" 2>/dev/null)
    local VERITY=$(adb shell "getprop ro.boot.vbmeta.device_state" 2>/dev/null)
    
    if [[ "$UNLOCKED" == "0" || "$VERITY" == "unlocked" ]]; then
        echo -e "  ${RED}✖ BOOTLOADER: DESBLOQUEADO (UNLOCKED)${RESET}"
        echo -e "  ${AMARELO}⚠ Risco: O sistema permite a instalação de kernels e ROMs modificadas.${RESET}"
        INTEGRITY_FAIL=1
    else
        echo -e "  ${VERDE}✔ BOOTLOADER: BLOQUEADO (LOCKED)${RESET}"
    fi

    # Auditoria de Horário e Vida do Sistema
    echo -e "\n${BRANCO}[ DATA, HORÁRIO E VIDA DO SISTEMA ]${RESET}"
    local TZ_INFO=$(adb shell "getprop persist.sys.timezone" 2>/dev/null)
    local UPTIME=$(adb shell "uptime" 2>/dev/null)
    echo -ne "  ${BRANCO}TIMEZONE:${RESET} $TZ_INFO "
    if [[ "$TZ_INFO" == *"Sao_Paulo"* || "$TZ_INFO" == *"Brasilia"* || "$TZ_INFO" == *"GMT-03:00"* ]]; then
        echo -e "${VERDE}(HORÁRIO DE BRASÍLIA VÁLIDO)${RESET}"
    else
        echo -e "${RED}(FORA DO HORÁRIO DE BRASÍLIA)${RESET}"
        echo -e "  ${AMARELO}⚠ Nota: Fuso incorreto indica tentativa de bypass em logs.${RESET}"
        INTEGRITY_FAIL=1
    fi
    echo -e "  ${CYAN}└─ Tempo de Atividade (Uptime):${RESET} $UPTIME"

    # Auditoria de Root, Magisk e Patches
    echo -e "\n${BRANCO}[ GERENCIADORES DE ROOT E MÓDULOS ]${RESET}"
    local SU_BIN=$(adb shell "ls /system/bin/su /system/xbin/su /data/adb/ksu /data/adb/magisk /data/adb/apatch /data/adb/folkpatch /data/adb/kowsu /data/adb/mambosu /data/adb/rksu /data/adb/suki /data/adb/ksu-next 2>/dev/null")
    local MAGISK_MODS=$(adb shell "ls /data/adb/modules 2>/dev/null")
    
    if [ -n "$SU_BIN" ]; then
        echo -e "  ${RED}✖ BINÁRIO SU: DETECTADO EM CAMINHOS CRÍTICOS!${RESET}"
        echo -e "     $SU_BIN"
        INTEGRITY_FAIL=1
    else
        echo -e "  ${VERDE}✔ Binário SU: Não localizado.${RESET}"
    fi

    if [ -n "$MAGISK_MODS" ]; then
        echo -e "  ${RED}✖ MÓDULOS MAGISK: ATIVOS E DETECTADOS!${RESET}"
        echo -e "     $MAGISK_MODS"
        INTEGRITY_FAIL=1
    else
        echo -e "  ${VERDE}✔ Módulos: Ambiente sem extensões ativas.${RESET}"
    fi

    echo -e "\n${AZUL}──────────────────────────────────────────────────────────────${RESET}"
    if [ "$INTEGRITY_FAIL" -eq 1 ]; then
        echo -e "${RED}      VEREDITO FINAL: SISTEMA VIOLADO / MODIFICADO!${RESET}"
    else 
        echo -e "${VERDE}      VEREDITO FINAL: TUDO VÁLIDO. AMBIENTE ÍNTEGRO.${RESET}"
    fi
    echo -e "${AZUL}──────────────────────────────────────────────────────────────${RESET}"
    read -p "Pressione Enter para retornar..."
}

ff_deep_scan() {
    PKG=$1
    NAME=$2
    header
    echo -e "${AMARELO}[!] Auditando ambiente de $NAME...${RESET}"
    local CHECK=$(adb shell "pm list packages | grep $PKG")
    if [ -z "$CHECK" ]; then
        echo -e "\n${RED}[!] ERRO: PACOTE NÃO LOCALIZADO.${RESET}"
    else
        echo -e "${VERDE}[OK] Ambiente Identificado.${RESET}\n"
        progress_bar "AUDITANDO REPLAYS"
        echo -e "${PURPLE}📌 ORIENTAÇÃO: Conferir data de modificação vs data da partida.${RESET}"
        local M_PATH="/sdcard/Android/data/$PKG/files/MReplays"
        local BINS=$(adb shell "ls -t $M_PATH 2>/dev/null" | grep '_rep\.bin' | head -n 3)
        if [ -z "$BINS" ]; then
            echo -e "${RED}[!] Sem replays locais.${RESET}"
        else
            while read -r bin; do
                [ -z "$bin" ] && continue
                local json="${bin%.bin}.json"
                local B_T=$(adb shell "stat -c '%y' '$M_PATH/$bin' 2>/dev/null | cut -d'.' -f1")
                echo -e "\n${VERDE}📄 DATA FILE:${RESET} $bin (Arquivo de telemetria da partida)"
                get_file_info "$M_PATH/$bin"
                local J_CHECK=$(adb shell "ls '$M_PATH/$json' 2>/dev/null")
                if [ -n "$J_CHECK" ]; then
                    local J_T=$(adb shell "stat -c '%y' '$M_PATH/$json' 2>/dev/null | cut -d'.' -f1")
                    echo -e "  ${AZUL}🔗 META-JSON:${RESET} $json | Sinc: $J_T"
                else 
                    echo -e "  ${RED}⚠️ META-JSON: AUSENTE (INDICA LIMPEZA MANUAL)${RESET}"
                fi
            done <<< "$BINS"
        fi
        echo -e "\n"
        progress_bar "SCAN MASSIVO 24H"
        local MASS_FILES=$(adb shell "find /sdcard/Android/data/$PKG/ /sdcard/Android/obb/$PKG/ /data/data/$PKG/ -type f -mmin -1440 2>/dev/null | sort -r | head -n 12")
        while read -r line; do
            [ -z "$line" ] && continue
            local T=$(adb shell "stat -c '%y' '$line' 2>/dev/null | cut -d'.' -f1")
            echo -e "\n${CYAN}🔍 OBJETO:${RESET} $line"
            echo -e "  ${AMARELO}🕒 Modif:${RESET} $T"
            echo -e "  ${BRANCO}🚩 Análise:${RESET} $(analyze_impact "$line")"
            get_file_info "$line"
        done <<< "$MASS_FILES"
    fi
    read -p "Pressione Enter para voltar..."
}

global_search() {
    header
    echo -e "${PURPLE}═══ BUSCA BRUTAL E MASSIVA: TODO O ANDROID ═══${RESET}"
    echo -ne "${AMARELO}[*] Mapeando diretórios (Aguarde conclusão total)...${RESET} "
    adb shell "find /sdcard/ -type f \( -iname '*.apk' -o -iname '*.html' -o -iname '*.pdf' -o -iname '*.doc*' -o -iname '*.txt' -o -iname '*.lua' -o -iname '*.sh' \) -print 2>/dev/null" > .lista_bruta
    sync
    echo -e "${VERDE}Concluído!${RESET}"
    mapfile -t EVIDENCIAS < .lista_bruta
    local TOTAL=${#EVIDENCIAS[@]}
    if [ "$TOTAL" -eq 0 ]; then
        echo -e "${RED}[!] Dispositivo limpo de evidências externas.${RESET}"
    else
        progress_bar "PROCESSANDO EVIDÊNCIAS"
        echo -e "\n${AMARELO}[!] Total de evidências detectadas: $TOTAL${RESET}"
        echo -e "${AZUL}────────────────────────────────────────────────────────────────${RESET}"
        for path in "${EVIDENCIAS[@]}"; do
            [ -z "$path" ] && continue
            local DATE=$(adb shell "stat -c '%y' '$path' 2>/dev/null | cut -d'.' -f1")
            echo -e "\n${BRANCO}📁 CAMINHO:${RESET} $path"
            echo -e "  ${RED}⚠️  RISCO / AÇÃO:${RESET} $(analyze_impact "$path")"
            echo -e "  ${AMARELO}🕒 MODIFICAÇÃO :${RESET} $DATE"
            get_file_info "$path"
            echo -e "${AZUL}  ──────────────────────────────────────────────────────────────${RESET}"
        done
    fi
    rm -f .lista_bruta
    read -p "Análise Finalizada. Pressione Enter..."
}

menu() {
    header
    local ADB_ST=$(adb devices | grep -v "List of devices" | grep "device$" | awk '{print $1}')
    if [ -z "$ADB_ST" ]; then
        ST="${RED}OFFLINE${RESET}"
    else 
        ST="${VERDE}ONLINE ($ADB_ST)${RESET}"
    fi
    echo -e " STATUS DA CONEXÃO: $ST"
    echo -e "${CYAN}╟──────────────────────────────────────────────────────────────╢${RESET}"
    echo -e "${BRANCO} [1]${RESET} AUDITORIA: Free Fire Global"
    echo -e "${BRANCO} [2]${RESET} AUDITORIA: Free Fire MAX"
    echo -e "${BRANCO} [3]${RESET} BUSCA BRUTAL (DEEP SCAN)"
    echo -e "${BRANCO} [4]${RESET} INTEGRITY, KERNEL & BOOTLOADER"
    echo -e "${BRANCO} [5]${RESET} REGISTRO DE USO (100 APPS)"
    echo -e "${BRANCO} [6]${RESET} CONECTAR: ADB WiFi (IP:Porta)"
    echo -e "${BRANCO} [7]${RESET} SAIR"
    echo -e "${CYAN}╟──────────────────────────────────────────────────────────────╢${RESET}"
    echo -ne "${AMARELO} SELECIONE: ${RESET}"
    read opt
}

while true; do
    menu
    case $opt in
        1) ff_deep_scan "com.dts.freefireth" "FF GLOBAL" ;;
        2) ff_deep_scan "com.dts.freefiremax" "FF MAX" ;;
        3) global_search ;;
        4) system_integrity_scan ;;
        5) usage_record_scan ;;
        6) echo -n "Endereço: "; read ip; adb connect $ip; sleep 2 ;;
        7) exit ;;
        *) echo -e "${RED}Opção inválida!${RESET}"; sleep 1 ;;
    esac
done